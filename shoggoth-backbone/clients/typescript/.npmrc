# Shoggoth TypeScript Client — npm Publish Configuration
#
# Publish with: npm publish --access public

{
  "name": "@shoggoth/client",
  "version": "0.1.0",
  "description": "TypeScript client for the Shoggoth Mesh Machine orchestrator API",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/chainchopper/shoggoth-backbone.git",
    "directory": "clients/typescript"
  },
  "homepage": "https://github.com/chainchopper/shoggoth-backbone#readme",
  "keywords": [
    "shoggoth",
    "gpu",
    "compute",
    "distributed",
    "fabric",
    "orchestrator",
    "webgpu",
    "vulkan",
    "cuda",
    "rocm",
    "machine-learning",
    "webrtc"
  ],
  "files": [
    "shoggoth-client.ts",
    "package.json",
    "README.md"
  ],
  "main": "shoggoth-client.ts",
  "types": "shoggoth-client.ts",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
