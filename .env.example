# ── Shoggoth Mesh Machine — Development Secrets ──────────────────────────────
# Copy this to .env and fill in real values.
# NEVER commit .env to version control.

# ── Orchestrator ───────────────────────────────────────────────────────────────
SHOGGOTH_DISCOVERY_ADDR=0.0.0.0:8888
SHOGGOTH_ORCHESTRATOR_PORT=9100
SHOGGOTH_TELEMETRY_PORT=9101
SHOGGOTH_METRICS_PORT=9102
RUST_LOG=shoggoth=info,shoggoth_orchestrator=debug

# ── Node Agent ─────────────────────────────────────────────────────────────────
SHOGGOTH_NODE_ID=bc250-01
SHOGGOTH_ORCHESTRATOR_ADDR=192.168.1.100:9100
SHOGGOTH_BROADCAST_ADDR=255.255.255.255:8888
SHOGGOTH_QUIC_PORT=9100

# ── mTLS ───────────────────────────────────────────────────────────────────────
SHOGGOTH_CA_CERT=/opt/shoggoth/certs/shoggoth-ca.crt
SHOGGOTH_TLS_CERT=/opt/shoggoth/certs/orchestrator/orchestrator.crt
SHOGGOTH_TLS_KEY=/opt/shoggoth/certs/orchestrator/orchestrator.key

# ── Cloud Provisioning ─────────────────────────────────────────────────────────
BREV_API_KEY=sk-brev-xxxxxxxxxxxx
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_DEFAULT_REGION=us-east-1
TAILSCALE_AUTH_KEY=tskey-auth-xxxxxxxxxxxx

# ── ScyllaDB ───────────────────────────────────────────────────────────────────
SCYLLA_NODES=192.168.1.10:9042,192.168.1.11:9042,192.168.1.12:9042
SCYLLA_KEYSPACE=genex

# ── API Authentication ─────────────────────────────────────────────────────────
SHOGGOTH_API_KEY=shoggoth-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SHOGGOTH_ADMIN_KEY=shoggoth-admin-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── NPU-STACK ──────────────────────────────────────────────────────────────────
NPU_STACK_PORT=8100
NPU_STACK_WORKERS=4
HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Docker ─────────────────────────────────────────────────────────────────────
SHOGGOTH_BACKUP_ROOT=/mnt/shoggoth-backups
SHOGGOTH_BACKUP_RETENTION_DAYS=30
